<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- Repair Ticket Sequence - Company 1 -->
        <record id="seq_repair_company_1" model="ir.sequence">
            <field name="name">Repair Sequence No</field>
            <field name="code">repair.seq</field>
            <field name="prefix">REPAIR/%(year)s/</field>
            <field name="number_next">2000</field>
            <field name="padding">5</field>
            <field name="company_id" ref="base.main_company"/>
        </record>

        <!-- Repair Serial Sequence - Company 1 -->
        <record id="seq_repair_serial_company_1" model="ir.sequence">
            <field name="name">Repair Serial Sequence No</field>
            <field name="code">repair.serial.seq</field>
            <field name="prefix">REP-SERIAL/%(year)s/</field>
            <field name="number_next">2000</field>
            <field name="padding">5</field>
            <field name="company_id" ref="base.main_company"/>
        </record>

    </data>
</odoo>
