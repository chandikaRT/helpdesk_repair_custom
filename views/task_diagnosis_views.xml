<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ═══════════════════════════════════════════
         Conditions
    ═══════════════════════════════════════════ -->

    <record id="view_conditions_tree" model="ir.ui.view">
        <field name="name">x_conditions.tree</field>
        <field name="model">x_conditions</field>
        <field name="arch" type="xml">
            <tree string="Conditions" editable="bottom">
                <field name="x_studio_sequence" widget="handle"/>
                <field name="x_name"/>
                <field name="x_studio_description"/>
                <field name="x_studio_company_id"/>
            </tree>
        </field>
    </record>

    <record id="view_conditions_form" model="ir.ui.view">
        <field name="name">x_conditions.form</field>
        <field name="model">x_conditions</field>
        <field name="arch" type="xml">
            <form string="Condition">
                <sheet>
                    <widget name="web_ribbon" title="Archived" bg_color="bg-danger"
                            invisible="x_active"/>
                    <field name="x_active" invisible="1"/>
                    <div class="oe_title">
                        <label for="x_name"/>
                        <h1><field name="x_name" placeholder="Condition"/></h1>
                    </div>
                    <group>
                        <field name="x_studio_description"/>
                        <field name="x_studio_sequence"/>
                        <field name="x_studio_company_id"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_conditions_search" model="ir.ui.view">
        <field name="name">x_conditions.search</field>
        <field name="model">x_conditions</field>
        <field name="arch" type="xml">
            <search string="Conditions">
                <field name="x_name"/>
                <filter string="Archived" name="inactive" domain="[('x_active', '=', False)]"/>
            </search>
        </field>
    </record>

    <record id="action_conditions" model="ir.actions.act_window">
        <field name="name">Conditions</field>
        <field name="res_model">x_conditions</field>
        <field name="view_mode">tree,form</field>
    </record>

