<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_repair_accounts_tree" model="ir.ui.view">
        <field name="name">x_repair_accounts.tree</field>
        <field name="model">x_repair_accounts</field>
        <field name="arch" type="xml">
            <tree create="true" delete="true" edit="true">
                <field name="x_studio_sequence" widget="handle"/>
                <field name="x_name"/>
                <field name="id" optional="show"/>
            </tree>
        </field>
    </record>

    <record id="view_repair_accounts_form" model="ir.ui.view">
        <field name="name">x_repair_accounts.form</field>
        <field name="model">x_repair_accounts</field>
        <field name="arch" type="xml">
            <form create="true">
                <header/>
                <sheet string="Repair Accounts">
                    <widget name="web_ribbon" text="Archived" bg_color="bg-danger"
                            invisible="x_active"/>
                    <field name="x_active" invisible="1"/>
                    <div class="oe_title">
                        <h1>
                            <field name="x_name" required="1" placeholder="Name..."/>
                        </h1>
                    </div>
                    <group name="studio_group_bf46f3">
                        <group name="studio_group_bf46f3_left" string="RUG Repair Accounts in Invoicing">
                            <field name="x_studio_rug_account" string="RUG Account" required="1"/>
                        </group>
                        <group name="studio_group_bf46f3_right">
                            <field name="x_studio_company_id" string="Company" force_save="True" readonly="1"/>
                        </group>
                    </group>
                </sheet>
                <div class="oe_chatter" name="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="message_ids"/>
                    <field name="activity_ids"/>
                </div>
            </form>
        </field>
    </record>

    <record id="view_repair_accounts_search" model="ir.ui.view">
        <field name="name">x_repair_accounts.search</field>
        <field name="model">x_repair_accounts</field>
        <field name="arch" type="xml">
            <search>
                <field name="x_name"/>
                <separator/>
                <filter string="Archived" name="archived_x_repair_accounts"
                        domain="[['x_active', '=', False]]"/>
                <separator/>
            </search>
        </field>
    </record>

    <record id="action_repair_accounts" model="ir.actions.act_window">
        <field name="name">Repair Accounts</field>
        <field name="res_model">x_repair_accounts</field>
        <field name="view_mode">tree,form</field>
    </record>

    <menuitem id="menu_repair_accounts"
              name="Repair Accounts"
              parent="helpdesk.helpdesk_menu_config"
              action="action_repair_accounts"
              sequence="7"/>

</odoo>
