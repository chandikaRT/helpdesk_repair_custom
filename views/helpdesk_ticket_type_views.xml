<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Form view for helpdesk.ticket.type with repair-specific fields -->
    <record id="helpdesk_ticket_type_view_form" model="ir.ui.view">
        <field name="name">helpdesk.ticket.type.form</field>
        <field name="model">helpdesk.ticket.type</field>
        <field name="arch" type="xml">
            <form string="Ticket Type">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="x_studio_rug" string="RUG"/>
                        <field name="x_studio_rug_confirmed" string="RUG Confirmed"
                               attrs="{'invisible': [('x_studio_rug','=',False)]}"/>
                        <field name="x_studio_with_serial_no" string="With Serial No"/>
                        <field name="x_studio_without_serial_no" string="Without Serial No"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

</odoo>
